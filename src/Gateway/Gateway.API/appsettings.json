{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Realm": "atlascommerce",
    "ClientId": "atlascommerce-api",
    "Authority": "htt://localhost:8080/realms/atlascommerce"
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "identity-users-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "identity-roles-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/roles/{**catch-all}"
        }
      },
      "identity-permissions-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/permissions/{**catch-all}"
        }
      },
      "catalog-public-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "catalog-categories-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "catalog-brands-route": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/brands/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "basket-route": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/basket/{**catch-all}"
        }
      },
      "search-route": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "https://localhost:7278"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "catalog-destination": {
            "Address": "https://localhost:7252"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-destination": {
            "Address": "https://localhost:7045"
          }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "basket-destination": {
            "Address": "https://localhost:7194"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "search-destination": {
            "Address": "https://localhost:7283"
          }
        }
      }
    }
  },
  "Jaeger": {
    "Endpoint": "http://localhost:4317"
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {"Name": "Identity API", "Uri": "https://localhost:7278/health-detail"},
      {"Name": "Catalog API", "Uri": "https://localhost:7252/health-detail"},
      {"Name": "Order API", "Uri": "https://localhost:7045/health-detail"},
      {"Name": "Basket API", "Uri": "https://localhost:7194/health-detail"},
      {"Name": "Search API", "Uri": "https://localhost:7283/health-detail"},
      {"Name": "API Gateway", "Uri": "https://localhost:7259/health-detail"}
    ],
    "EvaluationTimeInSeconds": 10,
    "MinimumSecondsBetweenFailureNotifications": 60
  }
}
